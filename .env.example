# ========================================
# 環境変数の設定ファイル（サンプル）
# ========================================
# このファイルをコピーして .env を作成し、
# 実際の値を入力してください。
# 例: cp .env.example .env
#
# ⚠️  .env ファイルは絶対にGitにコミットしないこと！
# ========================================

# サーバーのポート番号（デフォルト: 3000）
PORT=3000

# アプリの動作環境（development または production）
NODE_ENV=development

# ----------------------------------------
# 保活設定
# ----------------------------------------
# 入園を希望する年月を YYYY-MM 形式で設定してください。
# 設定しない（コメントアウト）場合は保活情報が表示されません。
# HOKATSU_TARGET_DATE=2027-04

# ----------------------------------------
# LINE Messaging API
# ----------------------------------------
# LINE Developers > チャネル基本設定 > チャネルシークレット
LINE_CHANNEL_SECRET=your_channel_secret_here
# LINE Developers > Messaging API設定 > チャネルアクセストークン（長期）
LINE_CHANNEL_ACCESS_TOKEN=your_access_token_here

# ----------------------------------------
# Google Sheets API
# ----------------------------------------
# スプレッドシートのURLに含まれるID
# 例: https://docs.google.com/spreadsheets/d/★ここ★/edit
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# サービスアカウントのメールアドレス（GCPコンソールで発行）
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@project.iam.gserviceaccount.com

# サービスアカウントの秘密鍵（改行は \n で1行にまとめる）
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
